<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        tools:context=".AddNoteActivity">

        <TextView
            android:id="@+id/tvNoteHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create New Note"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <EditText
            android:id="@+id/etTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Title"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/tvNoteHeader"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <RadioGroup
            android:id="@+id/rgNoteType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/etTitle"
            app:layout_constraintStart_toStartOf="parent">
            <RadioButton
                android:id="@+id/rbTextNote"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Text Note"
                android:checked="true" />
            <RadioButton
                android:id="@+id/rbChecklistNote"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Checklist" />
        </RadioGroup>

        <EditText
            android:id="@+id/etContent"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Content"
            android:inputType="textMultiLine"
            android:minLines="3"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/rgNoteType"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvUserHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="User Information"
            android:textSize="18sp"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/etContent"
            app:layout_constraintStart_toStartOf="parent" />

        <EditText
            android:id="@+id/etUserName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="User Name"
            app:layout_constraintTop_toBottomOf="@id/tvUserHeader"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <EditText
            android:id="@+id/etUserSex"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Sex"
            app:layout_constraintTop_toBottomOf="@id/etUserName"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/etUserAge" />

        <EditText
            android:id="@+id/etUserAge"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Age"
            android:inputType="number"
            app:layout_constraintTop_toBottomOf="@id/etUserName"
            app:layout_constraintStart_toEndOf="@id/etUserSex"
            app:layout_constraintEnd_toEndOf="parent" />

        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save Note"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/etUserAge" />

        <TextView
            android:id="@+id/tvSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Summary will appear here"
            android:background="#EEEEEE"
            android:padding="8dp"
            app:layout_constraintTop_toBottomOf="@id/btnSave" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>